    ],
  }

  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)

    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
      config.build_settings['SWIFT_VERSION'] = '5.0'
      config.build_settings['SWIFT_STRICT_CONCURRENCY'] = 'minimal'
      config.build_settings['GCC_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
      config.build_settings['SWIFT_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
      if target.name == 'Sentry'
        config.build_settings['BUILD_LIBRARY_FOR_DISTRIBUTION'] = 'YES'
      end
    end

    next unless target.respond_to?(:source_build_phase) && target.source_build_phase

    target.source_build_phase.files.each do |build_file|
      next unless build_file.file_ref
      next unless File.basename(build_file.file_ref.path.to_s) == 'PrivacyInfo.xcprivacy'

      target.source_build_phase.remove_build_file(build_file)
    end
  end

  plugin_source_patches.each do |plugin_path, replacements|
    next unless File.exist?(plugin_path)

    plugin_source = File.read(plugin_path)
    patched_source = plugin_source.dup
    replacements.each do |pattern, replacement|
      patched_source = patched_source.sub(pattern, replacement)
    end
    next if patched_source == plugin_source

    File.write(plugin_path, patched_source)
  end
end
