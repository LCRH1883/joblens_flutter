    File.join(__dir__, '.symlinks', 'plugins', 'photo_manager', 'darwin', 'photo_manager', 'Sources', 'photo_manager', 'core', 'PMMD5Utils.m') => [
      [/#import "PMMD5Utils\.h"\n\n@implementation PMMD5Utils/, "#import \"PMMD5Utils.h\"\n\n#pragma clang diagnostic push\n#pragma clang diagnostic ignored \"-Wdeprecated-declarations\"\n\n@implementation PMMD5Utils"],
